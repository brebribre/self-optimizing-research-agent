# Copy this file to .env and fill in your key(s).
# .env is gitignored.

# --- Anthropic (default provider) ---
ANTHROPIC_API_KEY=sk-ant-...

# Model the DSPy agent uses. Any LiteLLM-compatible id works.
# Default is Claude Sonnet. Swap to claude-opus-4-8 for higher quality,
# or claude-haiku-4-5-20251001 for cheaper/faster runs.
RESEARCH_AGENT_LM=anthropic/claude-sonnet-4-6

# Generation params
RESEARCH_AGENT_TEMPERATURE=0.7
RESEARCH_AGENT_MAX_TOKENS=4096

# --- Dataset pipeline (optional) ---
# Semantic Scholar API key for citation resolution (stage 4).
# Works without one (shared rate pool); a key gives a dedicated 1 req/s.
S2_API_KEY=
